# Production room-server settings for server/online-server.mjs
HOST=0.0.0.0
PORT=8787

# Comma-separated browser origins allowed to open WebSocket rooms.
# Use your Vercel/custom domain origin exactly.
ONLINE_ALLOWED_ORIGINS=https://your-game.vercel.app

# Capacity and abuse guardrails for the in-memory room server.
MAX_CLIENTS=200
MAX_ROOMS=100
MAX_MESSAGE_BYTES=4096

# Room lifecycle.
ROOM_TTL_MS=1800000
REJOIN_GRACE_MS=45000
HEARTBEAT_MS=30000
